<%- include("partials/head", { pageTitle, assetVersion }) %>
<%- include("partials/header", { appName, currentUser, flash, bootstrapError }) %>

<div id="offlineBanner" class="offline-banner" hidden>
  <span>You're offline — photos you upload will be queued and sent automatically when you reconnect</span>
</div>

<main class="page-shell">
  <section class="hero-card">
    <div class="hero-card__copy">
      <p class="eyebrow">Shared Catalogue</p>
      <h1>Search once, use everywhere</h1>
      <div class="hero-card__chips">
        <span class="chip" id="metaCountChip"><%= Number(catalogMeta.row_count || 0).toLocaleString() %> items</span>
        <% if (catalogMeta.imported_at) { %>
          <span class="chip" id="metaImportedChip">Imported <%= catalogMeta.imported_at %></span>
        <% } else { %>
          <span class="chip" id="metaImportedChip">No import yet</span>
        <% } %>
      </div>
    </div>
  </section>

  <% if (currentUser && currentUser.isAdmin) { %>
    <section class="metrics-grid metrics-grid--admin" id="summaryGrid">
      <article class="metric-card">
        <p class="eyebrow">Captured</p>
        <strong id="capturedSkuMetric">0</strong>
        <span id="capturedSkuMetricNote">SKUs with at least one image</span>
      </article>
      <article class="metric-card">
        <p class="eyebrow">Item File Coverage</p>
        <strong id="itemfileCoverageMetric">0%</strong>
        <span id="itemfileCoverageMetricNote">0 / 0 SKUs from the shared item file</span>
      </article>
      <article class="metric-card">
        <p class="eyebrow">Warehouse Coverage</p>
        <strong id="warehouseCoverageMetric">0%</strong>
        <span id="warehouseCoverageMetricNote">0 / 0 active warehouse SKUs captured</span>
      </article>
      <article class="metric-card">
        <p class="eyebrow">Warehouse Snapshot</p>
        <strong id="warehouseSnapshotMetric">Not synced</strong>
        <span id="warehouseSnapshotMetricNote">Waiting for the latest PI-App warehouse upload</span>
      </article>
    </section>
  <% } %>

  <% if (currentUser && currentUser.isAdmin) { %>
    <section class="panel-card">
      <div class="panel-head">
        <div>
          <p class="eyebrow">Admin Import</p>
          <h2>Publish a new workbook snapshot</h2>
          <p>Upload the latest client item file here and every refreshed PI-App machine will pick up the new shared catalogue.</p>
        </div>
        <span class="chip" id="importStatusChip">Idle</span>
      </div>
      <form id="importForm" class="import-form">
        <label class="field">
          <span>Workbook</span>
          <input type="file" name="catalog_file" id="catalogFile" accept=".xlsx,.xlsm,.xltx,.xltm,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet" required>
        </label>
        <button type="submit">Upload Workbook</button>
      </form>
    </section>
  <% } %>

  <section class="panel-card">
    <div class="panel-head">
      <div>
        <p class="eyebrow">Lookup</p>
        <h2>Filter catalogue and manage photos</h2>
        <p>Use several search filters together, scan product or box barcodes, preview reference images in a lightbox, and stage mobile photos inside each product card until you finalise the upload.</p>
      </div>
      <span class="chip" id="resultCountChip">0 matches</span>
    </div>
    <div class="search-panel">
      <div class="search-grid">
        <label class="field">
          <span>SKU / barcode</span>
          <input type="search" id="catalogSkuQuery" class="catalog-filter-input" placeholder="50012345 or barcode">
        </label>
        <label class="field">
          <span>Description filter 1</span>
          <input type="search" id="catalogDescOne" class="catalog-filter-input" placeholder="outer">
        </label>
        <label class="field">
          <span>Description filter 2</span>
          <input type="search" id="catalogDescTwo" class="catalog-filter-input" placeholder="20 inch">
        </label>
        <label class="field">
          <span>Description filter 3</span>
          <input type="search" id="catalogDescThree" class="catalog-filter-input" placeholder="olive / blue / glass">
        </label>
      </div>
      <div class="search-actions">
        <label class="toggle-pill">
          <input type="checkbox" id="hasImagesOnly">
          <span>Only with images</span>
        </label>
        <label class="toggle-pill">
          <input type="checkbox" id="warehouseActiveOnly">
          <span>Only active in warehouse</span>
        </label>
        <button type="button" class="ghost-button" id="scanBarcodeButton">Scan Barcode</button>
        <button type="button" id="searchButton">Search</button>
        <button type="button" class="ghost-button" id="clearButton">Clear</button>
      </div>
    </div>
    <div class="empty-state" id="emptyState">
      <strong><%= catalogMeta.available ? "Search to load catalogue items" : "No shared catalogue imported yet" %></strong>
      <span><%= catalogMeta.available ? "Use one filter or stack several together to narrow the results." : "An admin needs to upload the workbook first." %></span>
    </div>
    <div id="resultsGrid" class="results-grid"></div>
  </section>
</main>

<div id="imageLightbox" class="lightbox" hidden>
  <button type="button" class="lightbox__close" id="lightboxClose" aria-label="Close image viewer">&times;</button>
  <button type="button" class="lightbox__nav" id="lightboxPrev" aria-label="Previous image">Previous</button>
  <figure class="lightbox__frame">
    <img id="lightboxImage" src="" alt="">
    <figcaption class="lightbox__caption">
      <strong id="lightboxTitle"></strong>
      <span id="lightboxText"></span>
    </figcaption>
  </figure>
  <button type="button" class="lightbox__nav" id="lightboxNext" aria-label="Next image">Next</button>
</div>

<div id="barcodeScanner" class="scanner-modal" hidden>
  <div class="scanner-modal__panel">
    <div class="scanner-modal__head">
      <div>
        <p class="eyebrow">Barcode Scanner</p>
        <strong>Scan a product or box barcode</strong>
      </div>
      <button type="button" class="ghost-button scanner-modal__close" id="scannerCloseButton">Close</button>
    </div>
    <video id="scannerVideo" class="scanner-modal__video" playsinline muted></video>
    <div id="scannerFallbackRegion" class="scanner-modal__fallback" hidden></div>
    <p class="scanner-modal__status" id="scannerStatus">Point the camera at a barcode to search the shared catalogue.</p>
  </div>
</div>

<script>
  window.ITEMTRACKER_BOOTSTRAP = <%- safeJson({
    catalogMeta,
    maxResults,
    currentUser
  }) %>;
</script>
<script src="/static/js/catalogue.js?v=<%= assetVersion %>"></script>

<%- include("partials/footer", { assetVersion }) %>
