<header class="site-header">
  <div class="site-header__inner">
    <a href="/catalogue" class="brand-mark">
      <span class="brand-mark__eyebrow">Shared</span>
      <strong><%= appName %></strong>
    </a>
    <% if (currentUser) { %>
      <div class="site-header__actions">
        <% if (currentUser.isAdmin) { %>
          <a href="/picking-heatmap" class="ghost-button site-header__admin-link">Heatmap</a>
          <a href="/picking-reports" class="ghost-button site-header__admin-link">Reports</a>
          <a href="/admin" class="ghost-button site-header__admin-link">Admin</a>
        <% } %>
        <div class="user-chip">
          <span><%= currentUser.name %></span>
          <strong><%= currentUser.isAdmin ? "Admin" : "User" %></strong>
        </div>
        <form action="/logout" method="post">
          <button type="submit" class="ghost-button">Sign out</button>
        </form>
      </div>
    <% } %>
  </div>
</header>

<% if (bootstrapError) { %>
  <div class="notice-banner notice-banner--error">
    <strong>PocketBase bootstrap warning:</strong>
    <span><%= bootstrapError %></span>
  </div>
<% } %>

<% if (flash) { %>
  <div class="notice-banner notice-banner--<%= flash.category === "error" ? "error" : "success" %>">
    <span><%= flash.message %></span>
  </div>
<% } %>
