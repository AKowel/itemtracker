<%- include("partials/head", { pageTitle, assetVersion }) %>
<%- include("partials/header", { appName, currentUser, flash, bootstrapError }) %>

<main class="page-shell heatmap-page">
  <section class="hero-card heatmap-hero">
    <div class="hero-card__copy">
      <p class="eyebrow">Admin Only</p>
      <h1>Picking Heatmap</h1>
      <p>View live warehouse locations in 3D, colour them by pick activity, and click any location to inspect the current SKU, photos, and heat details.</p>
      <div class="hero-card__chips">
        <span class="chip" id="heatmapDateChip">Loading snapshots...</span>
        <span class="chip" id="heatmapSnapshotStatusChip">Checking snapshot status...</span>
        <span class="chip" id="heatmapLocationChip">0 locations</span>
        <span class="chip" id="heatmapPickChip">0 picks</span>
      </div>
      <p class="heatmap-hero__actions">
        <a href="/picking-reports" class="ghost-button">Open reports</a>
      </p>
    </div>
  </section>

  <section class="heatmap-fullscreen-shell" id="heatmapLayout">
    <section class="panel-card heatmap-toolbar-card">
      <div class="panel-head">
        <div>
          <p class="eyebrow">Controls</p>
          <h2>Scene Filters</h2>
          <p>Choose a published pick day or range and narrow the scene to the most useful locations.</p>
        </div>
      </div>
      <div class="heatmap-toolbar">
        <label class="field">
          <span>View mode</span>
          <select id="heatmapModeSelect">
            <option value="latest">Latest day</option>
            <option value="date">Specific date</option>
            <option value="last_7">Last week</option>
            <option value="last_30">Last month</option>
            <option value="custom">Custom range</option>
          </select>
        </label>
        <label class="field" id="heatmapDateField" hidden>
          <span>Pick snapshot date</span>
          <select id="heatmapDateSelect">
            <option value="">No snapshots yet</option>
          </select>
        </label>
        <label class="field" id="heatmapStartField" hidden>
          <span>Start date</span>
          <input type="date" id="heatmapStartDate">
        </label>
        <label class="field" id="heatmapEndField" hidden>
          <span>End date</span>
          <input type="date" id="heatmapEndDate">
        </label>
        <label class="field">
          <span>Heat metric</span>
          <select id="heatmapMetricSelect">
            <option value="pick_count">Pick count</option>
            <option value="pick_qty">Pick quantity</option>
          </select>
        </label>
        <label class="field">
          <span>Camera</span>
          <select id="heatmapCameraModeSelect">
            <option value="orbit">Perspective</option>
            <option value="top">Top-down</option>
            <option value="fps">FPS walk-through</option>
          </select>
        </label>
        <label class="field">
          <span>Colour mode</span>
          <select id="heatmapColourModeSelect">
            <option value="heatmap">Heatmap activity</option>
            <option value="binsize">Bin size</option>
            <option value="zone">Zone</option>
            <option value="level">Level</option>
          </select>
        </label>
        <label class="field heatmap-level-filter-field">
          <span>Visible levels</span>
          <div class="heatmap-level-filter">
            <input type="number" id="heatmapLevelMin" min="0" max="99" placeholder="Min">
            <span>to</span>
            <input type="number" id="heatmapLevelMax" min="0" max="99" placeholder="Max">
            <button type="button" class="ghost-button heatmap-level-reset" id="heatmapLevelResetButton">All</button>
          </div>
        </label>
        <label class="field">
          <span>Find location or SKU</span>
          <input type="search" id="heatmapSearchInput" placeholder="WF441002 or SKU">
        </label>
        <label class="toggle-pill">
          <input type="checkbox" id="heatmapPickedOnly">
          <span>Only picked locations</span>
        </label>
        <label class="toggle-pill">
          <input type="checkbox" id="heatmapOccupiedOnly">
          <span>Only occupied locations</span>
        </label>
        <button type="button" class="ghost-button" id="heatmapResetCameraButton">Reset camera</button>
        <button type="button" id="heatmapReloadButton">Reload</button>
      </div>
    </section>

    <section class="heatmap-layout-grid">
      <section class="panel-card heatmap-scene-card">
      <div class="panel-head">
        <div>
          <p class="eyebrow">3D Scene</p>
          <h2>Warehouse Rack View</h2>
          <p>Drag to orbit, scroll to zoom, and click a cube to inspect that location.</p>
        </div>
        <div class="heatmap-scene-actions">
          <a href="/layout-editor" class="ghost-button">Edit layout</a>
          <button type="button" class="ghost-button" id="heatmapSettingsButton" title="Scene settings">&#9881; Settings</button>
          <button type="button" class="ghost-button heatmap-fullscreen-button" id="heatmapFullscreenButton">Full screen</button>
          <span class="chip chip--inactive" id="heatmapStatusChip">Loading...</span>
        </div>
      </div>
      <div class="heatmap-scene-wrap">
        <canvas id="heatmapCanvas"></canvas>
        <div class="heatmap-settings-panel" id="heatmapSettingsPanel" hidden>
          <div class="heatmap-settings-panel__head">
            <strong>Scene Settings</strong>
            <button type="button" class="ghost-button heatmap-settings-close" id="heatmapSettingsClose">&#10005;</button>
          </div>
          <label class="heatmap-settings-row">
            <span>Orbit speed</span>
            <input type="range" id="rotateSpeedInput" min="0.1" max="4" step="0.1" value="1">
            <span id="rotateSpeedLabel" class="heatmap-settings-val">1.0</span>
          </label>
          <label class="heatmap-settings-row">
            <span>Zoom speed</span>
            <input type="range" id="zoomSpeedInput" min="0.1" max="6" step="0.1" value="1">
            <span id="zoomSpeedLabel" class="heatmap-settings-val">1.0</span>
          </label>
          <label class="heatmap-settings-row">
            <span>Pan speed</span>
            <input type="range" id="panSpeedInput" min="0.1" max="4" step="0.1" value="1">
            <span id="panSpeedLabel" class="heatmap-settings-val">1.0</span>
          </label>
          <label class="heatmap-settings-row">
            <span>WASD speed</span>
            <input type="range" id="wasdSpeedInput" min="0.3" max="6" step="0.1" value="1">
            <span id="wasdSpeedLabel" class="heatmap-settings-val">1.0&#215;</span>
          </label>
          <button type="button" class="ghost-button heatmap-settings-reset" id="heatmapSettingsReset">Reset defaults</button>
        </div>
        <div class="heatmap-scene-hint" id="heatmapSceneHint">
          <strong>Full screen controls</strong>
          <span><code>W A S D</code> move the camera, mouse drag orbits, scroll zooms, <code>Esc</code> exits.</span>
        </div>
        <div class="heatmap-fps-overlay" id="heatmapFpsOverlay" hidden>
          <div class="heatmap-fps-crosshair"></div>
          <div class="heatmap-fps-chip" id="heatmapFpsModeChip">FPS Look Mode</div>
          <div class="heatmap-fps-help">W A S D move · E / C up-down · mouse look · Tab toggles edit mode · Esc unlocks cursor</div>
        </div>
        <div class="heatmap-legend">
          <div class="heatmap-legend__bar"></div>
          <div class="heatmap-legend__labels">
            <span>Cool</span>
            <span>Warm</span>
            <span>Hot</span>
          </div>
        </div>
      </div>
      </section>

      <aside class="panel-card heatmap-sidebar">
      <div class="panel-head">
        <div>
          <p class="eyebrow">Selection</p>
          <h2>Location Detail</h2>
          <p id="heatmapDetailHint">Pick a location in the scene to load SKU and photo detail.</p>
        </div>
      </div>

      <div class="heatmap-stats-grid">
        <article class="metric-card">
          <p class="eyebrow">Occupied</p>
          <strong id="heatmapOccupiedMetric">0</strong>
          <span>locations with a live SKU</span>
        </article>
        <article class="metric-card">
          <p class="eyebrow">Picked</p>
          <strong id="heatmapPickedMetric">0</strong>
          <span>locations active in the selected view</span>
        </article>
      </div>

      <div id="heatmapSnapshotInfo" class="heatmap-snapshot-info">
        <strong>Checking snapshot availability...</strong>
      </div>

      <div id="heatmapDetailCard" class="heatmap-detail-card">
        <strong class="heatmap-detail-card__empty">No location selected yet.</strong>
      </div>

      <div class="panel-head heatmap-side-head">
        <div>
          <p class="eyebrow">Top Areas</p>
          <h2>Hottest aisles</h2>
        </div>
      </div>
      <div id="heatmapHotAisles" class="heatmap-hot-aisles">
        <p class="admin-loading">Loading...</p>
      </div>
      </aside>
    </section>
  </section>
</main>

<script>
  window.ITEMTRACKER_HEATMAP_BOOTSTRAP = <%- safeJson({
    currentUser
  }) %>;
</script>
<script type="importmap">
{
  "imports": {
    "three": "/vendor/three/build/three.module.js",
    "three/addons/": "/vendor/three/examples/jsm/"
  }
}
</script>
<script type="module" src="/static/js/heatmap.js?v=<%= assetVersion %>"></script>

<%- include("partials/footer", { assetVersion }) %>
